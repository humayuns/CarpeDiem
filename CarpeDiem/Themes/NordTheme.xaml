<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces and text -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFE5E9F0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9AA5B8"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFBF616A"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#FF4C566A"/>

    <!-- Header chips -->
    <SolidColorBrush x:Key="ChipTimeBackgroundBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ChipTimeForegroundBrush" Color="#FFD8DEE9"/>
    <SolidColorBrush x:Key="ChipDateBackgroundBrush" Color="#FF3B4A63"/>
    <SolidColorBrush x:Key="ChipDateForegroundBrush" Color="#FF88C0D0"/>

    <!-- Photo frames -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF353C4A"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FF4C566A"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF353C4A"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FF4C566A"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="#FF81A1C1"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FF434C5E"/>

    <!-- Diary day sections -->
    <SolidColorBrush x:Key="SectionBoxBrush" Color="#FF353C4A"/>
    <SolidColorBrush x:Key="SectionHighlightBrush" Color="#FF514633"/>
    <SolidColorBrush x:Key="SectionFlashBrush" Color="#FF31464F"/>

    <!-- Progress bars -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="BarTextBrush" Color="#FFE5E9F0"/>
    <SolidColorBrush x:Key="BarSecondBrush" Color="#FF5E8896"/>
    <SolidColorBrush x:Key="BarMinuteBrush" Color="#FF527A88"/>
    <SolidColorBrush x:Key="BarHourBrush" Color="#FF7E8C4E"/>
    <SolidColorBrush x:Key="BarDayBrush" Color="#FF9C8A4A"/>
    <SolidColorBrush x:Key="BarWeekBrush" Color="#FF4E7986"/>
    <SolidColorBrush x:Key="BarMonthBrush" Color="#FF55708F"/>
    <SolidColorBrush x:Key="BarYearBrush" Color="#FF678A55"/>
    <SolidColorBrush x:Key="BarCountdownBrush" Color="#FF5E8455"/>
    <SolidColorBrush x:Key="BarFoodTrackBrush" Color="#FF8A4E52"/>
    <SolidColorBrush x:Key="BarFoodFillBrush" Color="#FFA89554"/>
    <SolidColorBrush x:Key="BarInspirationBrush" Color="#FF55708F"/>
    <SolidColorBrush x:Key="BarMotivationBrush" Color="#FF96693C"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonStartBrush" Color="#FF5E8455"/>
    <SolidColorBrush x:Key="ButtonSpriteBrush" Color="#FF4E8294"/>
    <SolidColorBrush x:Key="ButtonDiaryBrush" Color="#FF4C6B96"/>
    <SolidColorBrush x:Key="ButtonClockBrush" Color="#FF5577A6"/>
    <SolidColorBrush x:Key="ButtonGoBrush" Color="#FF55794D"/>
    <SolidColorBrush x:Key="ButtonCloseBrush" Color="#FF9E5A52"/>
    <SolidColorBrush x:Key="ButtonRestoreBrush" Color="#FFA08146"/>
    <SolidColorBrush x:Key="ButtonMotivationBrush" Color="#FF8A6238"/>
    <SolidColorBrush x:Key="ButtonInspirationBrush" Color="#FF4C6B96"/>

</ResourceDictionary>
