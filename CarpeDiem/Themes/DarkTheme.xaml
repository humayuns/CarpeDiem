<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces and text -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E2025"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFE2E4EA"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9BA0AC"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFD98A85"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFF0F1F4"/>
    <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#FF4A4F5B"/>

    <!-- Header chips -->
    <SolidColorBrush x:Key="ChipTimeBackgroundBrush" Color="#FF2B2E36"/>
    <SolidColorBrush x:Key="ChipTimeForegroundBrush" Color="#FFC6CAD4"/>
    <SolidColorBrush x:Key="ChipDateBackgroundBrush" Color="#FF263244"/>
    <SolidColorBrush x:Key="ChipDateForegroundBrush" Color="#FF9FBDE4"/>

    <!-- Photo frames -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF26282F"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FF3A3D46"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF26282F"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FF464A55"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="#FF6F9BD9"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FF343947"/>

    <!-- Diary day sections -->
    <SolidColorBrush x:Key="SectionBoxBrush" Color="#FF26282F"/>
    <SolidColorBrush x:Key="SectionHighlightBrush" Color="#FF463A26"/>
    <SolidColorBrush x:Key="SectionFlashBrush" Color="#FF24424B"/>

    <!-- Progress bars -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FF30333B"/>
    <SolidColorBrush x:Key="BarTextBrush" Color="#FFDDE0E8"/>
    <SolidColorBrush x:Key="BarSecondBrush" Color="#FF3D7B81"/>
    <SolidColorBrush x:Key="BarMinuteBrush" Color="#FF376E78"/>
    <SolidColorBrush x:Key="BarHourBrush" Color="#FF6E7E3F"/>
    <SolidColorBrush x:Key="BarDayBrush" Color="#FF8C7C40"/>
    <SolidColorBrush x:Key="BarWeekBrush" Color="#FF356E7A"/>
    <SolidColorBrush x:Key="BarMonthBrush" Color="#FF465F8A"/>
    <SolidColorBrush x:Key="BarYearBrush" Color="#FF3F7A53"/>
    <SolidColorBrush x:Key="BarCountdownBrush" Color="#FF3B7A50"/>
    <SolidColorBrush x:Key="BarFoodTrackBrush" Color="#FF7A3D38"/>
    <SolidColorBrush x:Key="BarFoodFillBrush" Color="#FF9A8A3E"/>
    <SolidColorBrush x:Key="BarInspirationBrush" Color="#FF46618E"/>
    <SolidColorBrush x:Key="BarMotivationBrush" Color="#FF8C5E30"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonStartBrush" Color="#FF3C7E55"/>
    <SolidColorBrush x:Key="ButtonSpriteBrush" Color="#FF3E7E97"/>
    <SolidColorBrush x:Key="ButtonDiaryBrush" Color="#FF46679F"/>
    <SolidColorBrush x:Key="ButtonClockBrush" Color="#FF4A77A6"/>
    <SolidColorBrush x:Key="ButtonGoBrush" Color="#FF40804C"/>
    <SolidColorBrush x:Key="ButtonCloseBrush" Color="#FFA05A44"/>
    <SolidColorBrush x:Key="ButtonRestoreBrush" Color="#FFA67B40"/>
    <SolidColorBrush x:Key="ButtonMotivationBrush" Color="#FF8F6336"/>
    <SolidColorBrush x:Key="ButtonInspirationBrush" Color="#FF46679F"/>

</ResourceDictionary>
