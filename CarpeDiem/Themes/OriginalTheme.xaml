<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces and text -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF464646"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFF10000"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#FF798494"/>

    <!-- Header chips -->
    <SolidColorBrush x:Key="ChipTimeBackgroundBrush" Color="#FFE4E4E4"/>
    <SolidColorBrush x:Key="ChipTimeForegroundBrush" Color="#FF464646"/>
    <SolidColorBrush x:Key="ChipDateBackgroundBrush" Color="#FFC7DCFF"/>
    <SolidColorBrush x:Key="ChipDateForegroundBrush" Color="#FF464646"/>

    <!-- Photo frames -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFA8A8A8"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFA8A8A8"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="#FF2476EC"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FFCDE2FF"/>

    <!-- Progress bars -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="BarTextBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="BarSecondBrush" Color="#FF76DFE4"/>
    <SolidColorBrush x:Key="BarMinuteBrush" Color="#FF60C1CB"/>
    <SolidColorBrush x:Key="BarHourBrush" Color="#FF95B935"/>
    <SolidColorBrush x:Key="BarDayBrush" Color="#FFE4BE3B"/>
    <SolidColorBrush x:Key="BarWeekBrush" Color="#FF00828F"/>
    <SolidColorBrush x:Key="BarMonthBrush" Color="#FF2868B6"/>
    <SolidColorBrush x:Key="BarYearBrush" Color="#FF00971B"/>
    <SolidColorBrush x:Key="BarCountdownBrush" Color="#FF06B025"/>
    <SolidColorBrush x:Key="BarFoodTrackBrush" Color="#FFBD2E2E"/>
    <SolidColorBrush x:Key="BarFoodFillBrush" Color="#FFF3EA1C"/>
    <SolidColorBrush x:Key="BarInspirationBrush" Color="#FF06B025"/>
    <SolidColorBrush x:Key="BarMotivationBrush" Color="#FFBF6001"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonStartBrush" Color="#FF0CA83E"/>
    <SolidColorBrush x:Key="ButtonSpriteBrush" Color="#FF4AC8EE"/>
    <SolidColorBrush x:Key="ButtonDiaryBrush" Color="#FF2476EC"/>
    <SolidColorBrush x:Key="ButtonClockBrush" Color="#FF269EF1"/>
    <SolidColorBrush x:Key="ButtonGoBrush" Color="#FF22B900"/>
    <SolidColorBrush x:Key="ButtonCloseBrush" Color="#FFF15D26"/>
    <SolidColorBrush x:Key="ButtonRestoreBrush" Color="#FFF19E26"/>
    <SolidColorBrush x:Key="ButtonMotivationBrush" Color="#FFBF6001"/>
    <SolidColorBrush x:Key="ButtonInspirationBrush" Color="#FF1865C1"/>

</ResourceDictionary>
