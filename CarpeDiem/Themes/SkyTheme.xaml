<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces and text -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFEFF5FB"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF243447"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF5E7186"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFC4566B"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#FF7E93A8"/>

    <!-- Header chips -->
    <SolidColorBrush x:Key="ChipTimeBackgroundBrush" Color="#FFDEE9F4"/>
    <SolidColorBrush x:Key="ChipTimeForegroundBrush" Color="#FF3D5166"/>
    <SolidColorBrush x:Key="ChipDateBackgroundBrush" Color="#FFD2E4F7"/>
    <SolidColorBrush x:Key="ChipDateForegroundBrush" Color="#FF2D5380"/>

    <!-- Photo frames -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFAFCFE"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD3DFEC"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFBCCDDE"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="#FF3E8EDE"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FFE1ECF8"/>

    <!-- Diary day sections -->
    <SolidColorBrush x:Key="SectionBoxBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SectionHighlightBrush" Color="#FFD8E9FA"/>
    <SolidColorBrush x:Key="SectionFlashBrush" Color="#FFE5F3F8"/>

    <!-- Progress bars -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FFDFE8F1"/>
    <SolidColorBrush x:Key="BarTextBrush" Color="#FF243447"/>
    <SolidColorBrush x:Key="BarSecondBrush" Color="#FF8CD3E8"/>
    <SolidColorBrush x:Key="BarMinuteBrush" Color="#FF6BBCD9"/>
    <SolidColorBrush x:Key="BarHourBrush" Color="#FF9FC46A"/>
    <SolidColorBrush x:Key="BarDayBrush" Color="#FFE3C268"/>
    <SolidColorBrush x:Key="BarWeekBrush" Color="#FF63AFC4"/>
    <SolidColorBrush x:Key="BarMonthBrush" Color="#FF7FA3D8"/>
    <SolidColorBrush x:Key="BarYearBrush" Color="#FF7FC98B"/>
    <SolidColorBrush x:Key="BarCountdownBrush" Color="#FF52A86F"/>
    <SolidColorBrush x:Key="BarFoodTrackBrush" Color="#FFD08A80"/>
    <SolidColorBrush x:Key="BarFoodFillBrush" Color="#FFE8D684"/>
    <SolidColorBrush x:Key="BarInspirationBrush" Color="#FF6B95D6"/>
    <SolidColorBrush x:Key="BarMotivationBrush" Color="#FFCC9356"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonStartBrush" Color="#FF44A06A"/>
    <SolidColorBrush x:Key="ButtonSpriteBrush" Color="#FF4BA3C9"/>
    <SolidColorBrush x:Key="ButtonDiaryBrush" Color="#FF4E7FD0"/>
    <SolidColorBrush x:Key="ButtonClockBrush" Color="#FF5A93D6"/>
    <SolidColorBrush x:Key="ButtonGoBrush" Color="#FF49A45B"/>
    <SolidColorBrush x:Key="ButtonCloseBrush" Color="#FFD06A4E"/>
    <SolidColorBrush x:Key="ButtonRestoreBrush" Color="#FFD2A052"/>
    <SolidColorBrush x:Key="ButtonMotivationBrush" Color="#FFB07A45"/>
    <SolidColorBrush x:Key="ButtonInspirationBrush" Color="#FF4E7FD0"/>

</ResourceDictionary>
