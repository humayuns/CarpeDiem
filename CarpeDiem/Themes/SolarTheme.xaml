<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces and text -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF8F0DC"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF453F2E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF837A5F"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFBF5A33"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#FF9A9078"/>

    <!-- Header chips -->
    <SolidColorBrush x:Key="ChipTimeBackgroundBrush" Color="#FFEFE5C8"/>
    <SolidColorBrush x:Key="ChipTimeForegroundBrush" Color="#FF5C543C"/>
    <SolidColorBrush x:Key="ChipDateBackgroundBrush" Color="#FFF3E0B8"/>
    <SolidColorBrush x:Key="ChipDateForegroundBrush" Color="#FF7A5A28"/>

    <!-- Photo frames -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFDF8E9"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFE0D5B2"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFDF2"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFD4C79E"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="#FFB58900"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FFF2E8C9"/>

    <!-- Diary day sections -->
    <SolidColorBrush x:Key="SectionBoxBrush" Color="#FFFFFDF2"/>
    <SolidColorBrush x:Key="SectionHighlightBrush" Color="#FFF5DFA8"/>
    <SolidColorBrush x:Key="SectionFlashBrush" Color="#FFEAF0D8"/>

    <!-- Progress bars -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FFEDE3C5"/>
    <SolidColorBrush x:Key="BarTextBrush" Color="#FF453F2E"/>
    <SolidColorBrush x:Key="BarSecondBrush" Color="#FF8FCFC4"/>
    <SolidColorBrush x:Key="BarMinuteBrush" Color="#FF6FB8AC"/>
    <SolidColorBrush x:Key="BarHourBrush" Color="#FFA8B85C"/>
    <SolidColorBrush x:Key="BarDayBrush" Color="#FFD9B44A"/>
    <SolidColorBrush x:Key="BarWeekBrush" Color="#FF6FA8A0"/>
    <SolidColorBrush x:Key="BarMonthBrush" Color="#FF8AA4C8"/>
    <SolidColorBrush x:Key="BarYearBrush" Color="#FF93BD6E"/>
    <SolidColorBrush x:Key="BarCountdownBrush" Color="#FF859900"/>
    <SolidColorBrush x:Key="BarFoodTrackBrush" Color="#FFC97F62"/>
    <SolidColorBrush x:Key="BarFoodFillBrush" Color="#FFE6CD6B"/>
    <SolidColorBrush x:Key="BarInspirationBrush" Color="#FF6E9CC4"/>
    <SolidColorBrush x:Key="BarMotivationBrush" Color="#FFCB8A48"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonStartBrush" Color="#FF859900"/>
    <SolidColorBrush x:Key="ButtonSpriteBrush" Color="#FF2AA198"/>
    <SolidColorBrush x:Key="ButtonDiaryBrush" Color="#FF268BD2"/>
    <SolidColorBrush x:Key="ButtonClockBrush" Color="#FF6C8EC4"/>
    <SolidColorBrush x:Key="ButtonGoBrush" Color="#FF7A9E3B"/>
    <SolidColorBrush x:Key="ButtonCloseBrush" Color="#FFCB4B16"/>
    <SolidColorBrush x:Key="ButtonRestoreBrush" Color="#FFB58900"/>
    <SolidColorBrush x:Key="ButtonMotivationBrush" Color="#FFA1683A"/>
    <SolidColorBrush x:Key="ButtonInspirationBrush" Color="#FF268BD2"/>

</ResourceDictionary>
