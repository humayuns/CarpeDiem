<Window x:Class="Diary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarpeDiem"
        mc:Ignorable="d"
        Title="Diary" Height="600" Width="800" MinHeight="420" MinWidth="600" Loaded="Window_Loaded"
        Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Notes editor. Declared before textBoxFontSize: its TextChanged handler
             references this element during XAML load. Background stays white because
             the code-behind animates it (Azure -> White) on date changes. -->
        <TextBox x:Name="textBox" Grid.Column="1" Margin="8,0,0,0"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Background="White" Foreground="#FF1A1A1A" CaretBrush="#FF1A1A1A"/>

        <!-- Side panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Calendar x:Name="Calendar1" Grid.Row="0" HorizontalAlignment="Left"/>

            <Grid Grid.Row="1" Margin="0,6,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="label" Grid.Column="0" Content="Special Symbols" Padding="0,0,0,2"
                       VerticalAlignment="Center" FontWeight="Bold" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Button x:Name="buttonCurrentDate" Grid.Column="1" Content="🗓" Width="30" Height="22"
                        Margin="4,0,0,0" Padding="0" ToolTip="Go to today"/>
                <Button x:Name="buttonFolder" Grid.Column="2" Content="📂" Width="30" Height="22"
                        Margin="4,0,0,0" Padding="0" ToolTip="Open day folder"/>
            </Grid>

            <TextBox x:Name="textBoxSpecial" Grid.Row="2"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <Grid Grid.Row="3" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="comboBox" Grid.Column="0" Height="28"
                          ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"/>
                <TextBox x:Name="textBoxFontSize" Grid.Column="1" Width="42" Height="28" Margin="4,0,0,0" Padding="2,3"
                         Text="12" TextAlignment="Center" ToolTip="Font size"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
