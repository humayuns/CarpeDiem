<Window x:Class="Diary2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarpeDiem"
        mc:Ignorable="d"
        Title="Diary2" Height="600" Width="800" MinHeight="420" MinWidth="620" Loaded="Window_Loaded"
        Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Side panel -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Calendar x:Name="Calendar1" Grid.Row="0" HorizontalAlignment="Left"/>

            <Grid Grid.Row="1" Margin="0,6,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="label" Grid.Column="0" Content="Symbols" Padding="0,0,0,2"
                       VerticalAlignment="Center" FontWeight="Bold" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Button x:Name="buttonPreviousDate" Grid.Column="1" Content="◀" Width="28" Height="22"
                        Margin="3,0,0,0" Padding="0" FontSize="10" ToolTip="Previous Date"/>
                <Button x:Name="buttonNextDate" Grid.Column="2" Content="▶" Width="28" Height="22"
                        Margin="3,0,0,0" Padding="0" FontSize="10" ToolTip="Next Date"/>
                <!-- Dark text: the code-behind sets this button's background to LightBlue/Yellow. -->
                <Button x:Name="buttonCurrentDate" Grid.Column="3" Content="🗓" Width="28" Height="22"
                        Margin="3,0,0,0" Padding="0" Foreground="#FF1A1A1A" ToolTip="Current Date"/>
                <Button x:Name="buttonFolder" Grid.Column="4" Content="📂" Width="28" Height="22"
                        Margin="3,0,0,0" Padding="0" ToolTip="Open Current Day Folder"/>
            </Grid>

            <TextBox x:Name="textBoxSpecial" Grid.Row="2"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <Grid Grid.Row="3" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="comboBox" Grid.Column="0" Height="24"
                          ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"/>
                <TextBox x:Name="textBoxFontSize" Grid.Column="1" Width="42" Height="24" Margin="4,0,0,0" Padding="2,3"
                         Text="12" TextAlignment="Center" ToolTip="Font size"/>
            </Grid>
        </Grid>

        <!-- Tabs -->
        <TabControl x:Name="tabControl" Grid.Column="1">
            <TabItem Header="Sections">
                <!-- The code-behind swaps each box between SectionBoxBrush and
                     SectionHighlightBrush as the day section changes. -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="textBox1" Grid.Row="0" Margin="0,0,0,4"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SectionBoxBrush}"/>
                    <TextBox x:Name="textBox2" Grid.Row="1" Margin="0,0,0,4"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SectionBoxBrush}"/>
                    <TextBox x:Name="textBox3" Grid.Row="2" Margin="0,0,0,4"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SectionBoxBrush}"/>
                    <Grid Grid.Row="3" Height="22">
                        <ProgressBar x:Name="ProgressBar1"
                                     Foreground="{DynamicResource BarDayBrush}"
                                     Background="{DynamicResource BarTrackBrush}"/>
                        <TextBlock x:Name="Progressbar1Text" Style="{StaticResource BarLabel}">Time</TextBlock>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Day">
                <TextBox x:Name="textBoxDay"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </TabItem>
            <TabItem Header="Monospace">
                <TextBox x:Name="textBoxMonoSpace"
                         TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" VerticalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Fira Code, Consolas"/>
            </TabItem>
            <TabItem Header="RichText">
                <!-- White background: loaded RTF carries its own (dark) text colors. -->
                <RichTextBox x:Name="richTextBox" Background="White" Foreground="#FF1A1A1A" CaretBrush="#FF1A1A1A">
                    <FlowDocument/>
                </RichTextBox>
            </TabItem>
            <TabItem Header="Tools">
                <WrapPanel Orientation="Horizontal" Margin="4">
                    <Button x:Name="btnSmoothDraw" Content="🌼 SmoothDraw" Width="110" Height="24" Margin="0,0,6,6"/>
                    <Button x:Name="btnSketchBook" Content="✎ SketchBook" Width="110" Height="24" Margin="0,0,6,6"/>
                    <Button x:Name="btnWordDoc" Content="✍ Word Doc" Width="110" Height="24" Margin="0,0,6,6"/>
                    <Button x:Name="btnWordPad" Content="✏ WordPad" Width="110" Height="24" Margin="0,0,6,6"/>
                    <Button x:Name="btnPhotoshop" Content="✨ Photoshop" Width="110" Height="24" Margin="0,0,6,6"/>
                    <Button x:Name="btnMathematica" Content="✡ Mathematica" Width="110" Height="24" Margin="0,0,6,6"/>
                </WrapPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
