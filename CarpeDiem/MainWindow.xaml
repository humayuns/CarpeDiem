<Window x:Class="MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Carpe Diem" Height="328.81" Width="586" MinWidth="500" MinHeight="300"
    ResizeMode="CanResize" Loaded="Window_Loaded" MouseDown="Window_MouseDown" SizeChanged="Window_SizeChanged" Icon="Images/ClearD-A.ico">
    <Grid Unloaded="Grid_Unloaded" MouseRightButtonUp="Grid_MouseRightButtonUp">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="menuItemAlwaysOnTop" Header="Always on Top" IsCheckable="True" Click="menuItemAlwaysOnTop_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid.RowDefinitions>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Time progress bars + portrait image -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Profile + countdown bar + bio bars with inline buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Hours / target row -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Buttons row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ── -->
        <Grid Grid.Row="0" Margin="6,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="labelTitle" Grid.Column="0" Content="Carpe Diem"
                   Foreground="#FFF10000" FontStyle="Italic" FontWeight="Bold"
                   VerticalAlignment="Center" Padding="0,0,8,0"/>
            <!-- spacer -->
            <Label x:Name="labelTime" Grid.Column="2" Content="00:00:00 AM"
                   Foreground="#FF464646" FontFamily="Fira Code Medium"
                   Background="#FFE4E4E4" BorderBrush="#FFA8A8A8" BorderThickness="1"
                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Label x:Name="labelTimeUTC" Grid.Column="3" Content="Weekday, Month 00, 0000"
                   Foreground="#FF464646" FontFamily="Fira Code Medium"
                   Background="#FFC7DCFF" BorderBrush="#FFA8A8A8" BorderThickness="1"
                   FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Row 1: Time progress bars (left) + portrait (right) ── -->
        <Grid Grid.Row="1" Margin="6,0,6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Progress bars stack -->
            <UniformGrid x:Name="ProgressBarsGrid" Grid.Column="0" Rows="7" Margin="0,2,6,2">
                <Grid>
                    <ProgressBar x:Name="ProgressbarSecond" Foreground="#FF76DFE4"/>
                    <TextBlock x:Name="ProgressbarSecondText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">SECOND</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarMinute" Foreground="#FF60C1CB"/>
                    <TextBlock x:Name="ProgressbarMinuteText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">MINUTE</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarHour" Foreground="#FF95B935"/>
                    <TextBlock x:Name="ProgressbarHourText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">HOUR</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarDay" Foreground="#FFE4BE3B"/>
                    <TextBlock x:Name="ProgressbarDayText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">DAY</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarWeek" Foreground="#FF00828F"/>
                    <TextBlock x:Name="ProgressbarWeekText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">WEEK</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarMonth" Foreground="#FF2868B6"/>
                    <TextBlock x:Name="ProgressbarMonthText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">MONTH</TextBlock>
                </Grid>
                <Grid>
                    <ProgressBar x:Name="ProgressbarLT" Foreground="#FF00971B"/>
                    <TextBlock x:Name="ProgressbarLTText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8">YEAR</TextBlock>
                </Grid>
            </UniformGrid>

            <!-- Portrait image -->
            <Image x:Name="image" Grid.Column="1" Source="Images/John-Keating.jpg"
                   Width="113" Height="113" VerticalAlignment="Center"
                   Stretch="Uniform"/>
        </Grid>

        <!-- ── Row 2: Profile image + bars + inline action buttons ── -->
        <Grid Grid.Row="2" Margin="6,4,6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Profile photo -->
            <Image x:Name="image_Copy" Grid.Column="0" Source="Images/profile100.png"
                   Width="70" Height="70" VerticalAlignment="Center" Margin="0,0,6,0"
                   Stretch="Uniform"/>

            <!-- Bars + buttons -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Countdown bar -->
                <ProgressBar x:Name="Progressbar1" Grid.Row="0" Height="32" Margin="0,0,0,2"/>

                <!-- Food bar + Restore button -->
                <Grid Grid.Row="1" Margin="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ProgressbarFood" Grid.Column="0" Height="15"
                                 Background="#FFBD2E2E" Foreground="#FFF3EA1C" Value="100"/>
                    <Button x:Name="buttonFood" Grid.Column="1" Content="Restore" Width="75" Height="15"
                            Background="#FFF19E26" FontSize="9" Foreground="White" Margin="3,0,0,0"/>
                </Grid>

                <!-- Inspiration bar -->
                <ProgressBar x:Name="ProgressbarInspiration" Grid.Row="2" Height="8"
                             Background="#FF9E9E9E" Value="100" Margin="0,0,0,1"/>

                <!-- Motivation bar -->
                <ProgressBar x:Name="ProgressbarMotivation" Grid.Row="3" Height="8"
                             Background="#FF9E9E9E" Foreground="#FFBF6001" Value="100" Margin="0,0,0,1"/>

                <!-- Hours left label + target -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label x:Name="label" Grid.Column="0" Content="Hours" VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="labelHoursLeft" Grid.Column="1" Content="00" VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="labelTarget" Grid.Column="2" Content="Target" VerticalAlignment="Center"/>
                    <Button x:Name="buttonMotivation" Grid.Column="3" Content="Motivation" Width="75" Height="15"
                            Background="#FFBF6001" FontSize="9" Foreground="#FFFFDADA" Margin="3,0,0,0"/>
                    <Button x:Name="buttonInspiration" Grid.Column="4" Content="Inspiration" Width="75" Height="15"
                            Background="#FF1865C1" FontSize="9" Foreground="White" Margin="3,0,0,0"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ── Row 3: Hours input ── -->
        <Grid Grid.Row="3" Margin="6,4,6,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="textBoxHours" Grid.Column="0" Width="71" Height="23"
                     TextWrapping="Wrap" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Row 4: Buttons ── -->
        <WrapPanel Grid.Row="4" Orientation="Horizontal" Margin="6,2,6,6">
            <Button x:Name="button" Content="Start Day" Width="75" Margin="0,0,4,0" Background="#FF0CA83E"/>
            <Button x:Name="buttonSprite" Content="Sprite" Width="75" Margin="0,0,4,0" Background="#FF4AC8EE"/>
            <Button x:Name="buttonClock_Copy" Content="Diary" Width="75" Margin="0,0,4,0" Background="#FF2476EC"/>
            <Button x:Name="buttonClock" Content="Clock" Width="75" Margin="0,0,4,0" Background="#FF269EF1"/>
            <ComboBox x:Name="comboBox" Width="120" Margin="0,0,4,0" VerticalAlignment="Center">
                <ComboBoxItem Content="CountDown"/>
                <ComboBoxItem Content="Stop Watch"/>
                <ComboBoxItem Content="Focus"/>
                <ComboBoxItem Content="Body Clock"/>
                <ComboBoxItem Content="Calendar"/>
                <ComboBoxItem Content="Ability"/>
                <ComboBoxItem Content="Diary"/>
                <ComboBoxItem Content="Diary2"/>
            </ComboBox>
            <Button x:Name="buttonGo" Content="Go" Width="30" Margin="0,0,4,0" Background="#FF22B900"/>
            <Button x:Name="buttonClose" Content="Close" Width="75" Background="#FFF15D26"/>
        </WrapPanel>

    </Grid>
</Window>
