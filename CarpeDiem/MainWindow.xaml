<Window x:Class="MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Carpe Diem" Height="360" Width="620" MinWidth="520" MinHeight="330"
    ResizeMode="CanResize" Loaded="Window_Loaded" MouseDown="Window_MouseDown" SizeChanged="Window_SizeChanged" Icon="Images/ClearD-A.ico"
    Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
    UseLayoutRounding="True" SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display">

    <!-- Shared themes and control styles live in Application.Resources (Themes/*.xaml). -->

    <Grid Unloaded="Grid_Unloaded" MouseRightButtonUp="Grid_MouseRightButtonUp" Margin="10">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="menuItemAlwaysOnTop" Header="Always on Top" IsCheckable="True" Click="menuItemAlwaysOnTop_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid.RowDefinitions>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Time progress bars + portrait image -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Profile + countdown bar + bio bars with inline buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Hours input row -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Buttons row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ── -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="labelTitle" Grid.Column="0" Content="Carpe Diem"
                   Foreground="{DynamicResource TitleBrush}" FontStyle="Italic" FontWeight="Bold" FontSize="15"
                   VerticalAlignment="Center" Padding="0,0,8,0"/>
            <!-- spacer -->
            <Border Grid.Column="2" Style="{StaticResource TimeChip}" Background="{DynamicResource ChipTimeBackgroundBrush}" Margin="0,0,6,0">
                <Label x:Name="labelTime" Content="00:00:00 AM" Padding="0"
                       Foreground="{DynamicResource ChipTimeForegroundBrush}"
                       FontFamily="Fira Code Medium, Consolas" FontWeight="Bold"/>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource TimeChip}" Background="{DynamicResource ChipDateBackgroundBrush}">
                <Label x:Name="labelTimeUTC" Content="Weekday, Month 00, 0000" Padding="0"
                       Foreground="{DynamicResource ChipDateForegroundBrush}"
                       FontFamily="Fira Code Medium, Consolas" FontWeight="Bold"/>
            </Border>
            <Button x:Name="buttonTheme" Grid.Column="4" Content="☼" FontSize="13" Width="28" Height="23"
                    Margin="6,0,0,0" Padding="0" ToolTip="Switch to soft mode"
                    Background="{DynamicResource ChipTimeBackgroundBrush}"
                    Foreground="{DynamicResource ChipTimeForegroundBrush}"/>
        </Grid>

        <!-- ── Row 1: Time progress bars (left) + portrait (right) ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Progress bars stack -->
            <UniformGrid x:Name="ProgressBarsGrid" Grid.Column="0" Rows="7" Margin="0,0,8,0">
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarSecond" Foreground="{DynamicResource BarSecondBrush}"/>
                    <TextBlock x:Name="ProgressbarSecondText" Style="{StaticResource BarLabel}">SECOND</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarMinute" Foreground="{DynamicResource BarMinuteBrush}"/>
                    <TextBlock x:Name="ProgressbarMinuteText" Style="{StaticResource BarLabel}">MINUTE</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarHour" Foreground="{DynamicResource BarHourBrush}"/>
                    <TextBlock x:Name="ProgressbarHourText" Style="{StaticResource BarLabel}">HOUR</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarDay" Foreground="{DynamicResource BarDayBrush}"/>
                    <TextBlock x:Name="ProgressbarDayText" Style="{StaticResource BarLabel}">DAY</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarWeek" Foreground="{DynamicResource BarWeekBrush}"/>
                    <TextBlock x:Name="ProgressbarWeekText" Style="{StaticResource BarLabel}">WEEK</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarMonth" Foreground="{DynamicResource BarMonthBrush}"/>
                    <TextBlock x:Name="ProgressbarMonthText" Style="{StaticResource BarLabel}">MONTH</TextBlock>
                </Grid>
                <Grid Margin="0,1.5">
                    <ProgressBar x:Name="ProgressbarLT" Foreground="{DynamicResource BarYearBrush}"/>
                    <TextBlock x:Name="ProgressbarLTText" Style="{StaticResource BarLabel}">YEAR</TextBlock>
                </Grid>
            </UniformGrid>

            <!-- Portrait image -->
            <Border Grid.Column="1" Style="{StaticResource PhotoFrame}">
                <Image x:Name="image" Source="Images/John-Keating.jpg"
                       Width="113" Height="113" Stretch="Uniform"/>
            </Border>
        </Grid>

        <!-- ── Row 2: Profile image + bars + inline action buttons ── -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Profile photo -->
            <Border Grid.Column="0" Style="{StaticResource PhotoFrame}" Margin="0,0,8,0">
                <Image x:Name="image_Copy" Source="Images/profile100.png"
                       Width="70" Height="70" Stretch="Uniform"/>
            </Border>

            <!-- Bars + buttons -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Countdown bar -->
                <ProgressBar x:Name="Progressbar1" Grid.Row="0" Height="30"
                             Foreground="{DynamicResource BarCountdownBrush}" Margin="0,0,0,4"/>

                <!-- Food bar + Restore button -->
                <Grid Grid.Row="1" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ProgressbarFood" Grid.Column="0" Height="16"
                                 Background="{DynamicResource BarFoodTrackBrush}"
                                 Foreground="{DynamicResource BarFoodFillBrush}" Value="100"/>
                    <Button x:Name="buttonFood" Grid.Column="1" Content="Restore" Width="75" Height="18"
                            Background="{DynamicResource ButtonRestoreBrush}" FontSize="10" Padding="0" Margin="4,0,0,0"/>
                </Grid>

                <!-- Inspiration bar -->
                <ProgressBar x:Name="ProgressbarInspiration" Grid.Row="2" Height="8"
                             Foreground="{DynamicResource BarInspirationBrush}" Value="100" Margin="0,0,0,3"/>

                <!-- Motivation bar -->
                <ProgressBar x:Name="ProgressbarMotivation" Grid.Row="3" Height="8"
                             Foreground="{DynamicResource BarMotivationBrush}" Value="100" Margin="0,0,0,3"/>

                <!-- Hours left label + target -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label x:Name="label" Grid.Column="0" Content="Hours" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="labelHoursLeft" Grid.Column="1" Content="00" Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="Bold" VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="labelTarget" Grid.Column="2" Content="Target" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                    <Button x:Name="buttonMotivation" Grid.Column="3" Content="Motivation" Width="75" Height="18"
                            Background="{DynamicResource ButtonMotivationBrush}" FontSize="10" Padding="0" Margin="4,0,0,0"/>
                    <Button x:Name="buttonInspiration" Grid.Column="4" Content="Inspiration" Width="75" Height="18"
                            Background="{DynamicResource ButtonInspirationBrush}" FontSize="10" Padding="0" Margin="4,0,0,0"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ── Row 3: Hours input ── -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Plan hours:" Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" Padding="0,0,6,0"/>
            <TextBox x:Name="textBoxHours" Grid.Column="1" Width="80" Height="24"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Row 4: Buttons ── -->
        <WrapPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="button" Content="Start Day" Width="78" Height="26" Margin="0,0,5,0" Background="{DynamicResource ButtonStartBrush}"/>
            <Button x:Name="buttonSprite" Content="Sprite" Width="78" Height="26" Margin="0,0,5,0" Background="{DynamicResource ButtonSpriteBrush}"/>
            <Button x:Name="buttonClock_Copy" Content="Diary" Width="78" Height="26" Margin="0,0,5,0" Background="{DynamicResource ButtonDiaryBrush}"/>
            <Button x:Name="buttonClock" Content="Clock" Width="78" Height="26" Margin="0,0,5,0" Background="{DynamicResource ButtonClockBrush}"/>
            <ComboBox x:Name="comboBox" Width="120" Height="26" Margin="0,0,5,0" VerticalAlignment="Center"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="CountDown"/>
                <ComboBoxItem Content="Stop Watch"/>
                <ComboBoxItem Content="Focus"/>
                <ComboBoxItem Content="Body Clock"/>
                <ComboBoxItem Content="Calendar"/>
                <ComboBoxItem Content="Ability"/>
                <ComboBoxItem Content="Diary"/>
                <ComboBoxItem Content="Diary2"/>
            </ComboBox>
            <Button x:Name="buttonGo" Content="Go" Width="36" Height="26" Margin="0,0,5,0" Background="{DynamicResource ButtonGoBrush}"/>
            <Button x:Name="buttonClose" Content="Close" Width="78" Height="26" Background="{DynamicResource ButtonCloseBrush}"/>
        </WrapPanel>

    </Grid>
</Window>
