<Window x:Class="Quotes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarpeDiem"
        mc:Ignorable="d"
        Title="Quotes" Height="260" Width="440" MinHeight="200" MinWidth="340" WindowStyle="ToolWindow"
        Loaded="Window_Loaded"
        Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TimeChip}" VerticalAlignment="Stretch"
                Background="{DynamicResource ChipDateBackgroundBrush}" Padding="14,10">
            <TextBlock x:Name="textQuote" TextWrapping="Wrap" FontSize="16" FontStyle="Italic"
                       Foreground="{DynamicResource ChipDateForegroundBrush}"
                       VerticalAlignment="Center" TextAlignment="Center"/>
        </Border>

        <Label x:Name="labelAuthor" Grid.Row="1" Content="" Padding="0" Margin="0,6,2,0"
               HorizontalAlignment="Right" FontWeight="SemiBold"
               Foreground="{DynamicResource TextSecondaryBrush}"/>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="buttonCopy" Grid.Column="0" Content="📋 Copy" Width="78" Height="24"
                    Background="{DynamicResource ButtonNeutralBrush}" ToolTip="Copy quote to clipboard"/>
            <Button x:Name="buttonNext" Grid.Column="2" Content="Next ▶" Width="78" Height="24"
                    Background="{DynamicResource ButtonClockBrush}"/>
        </Grid>
    </Grid>
</Window>
