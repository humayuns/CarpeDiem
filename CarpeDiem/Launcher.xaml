<Window x:Class="Launcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarpeDiem"
        mc:Ignorable="d"
        Title="Launcher" Height="290" Width="340" WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Open a tool" Padding="0,0,0,6"
               FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <Button x:Name="buttonCountDown" Content="⏳ CountDown" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonClockBrush}"/>
            <Button x:Name="buttonStopWatch" Content="⏱ Stop Watch" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonSpriteBrush}"/>
            <Button x:Name="buttonFocus" Content="🎯 Focus" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonStartBrush}"/>
            <Button x:Name="buttonBodyClock" Content="🕰 Body Clock" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonMotivationBrush}"/>
            <Button x:Name="buttonCalendar" Content="📅 Calendar" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonDiaryBrush}"/>
            <Button x:Name="buttonAbility" Content="✨ Ability" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonGoBrush}"/>
            <Button x:Name="buttonDiary" Content="📔 Diary" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonInspirationBrush}"/>
            <Button x:Name="buttonDiary2" Content="📓 Diary2" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonRestoreBrush}"/>
            <Button x:Name="buttonPomodoro" Content="🍅 Pomodoro" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonCloseBrush}"/>
            <Button x:Name="buttonQuotes" Content="💬 Quotes" Margin="3" MinHeight="32"
                    Background="{DynamicResource ButtonNeutralBrush}"/>
        </UniformGrid>
    </Grid>
</Window>
