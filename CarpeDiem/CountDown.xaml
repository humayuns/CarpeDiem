<Window x:Class="CountDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarpeDiem"
        mc:Ignorable="d"
        Title="CountDown" Height="150" Width="250" WindowStyle="ToolWindow" Loaded="Window_Loaded"
        Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TimeChip}" VerticalAlignment="Stretch"
                Background="{DynamicResource ChipTimeBackgroundBrush}">
            <Label x:Name="labelTime" Content="00:00:00" Padding="0" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource ChipTimeForegroundBrush}"
                   FontFamily="Fira Code Medium, Consolas"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <ProgressBar x:Name="ProgressBar1" Grid.Row="1" Height="5" Margin="0,8,0,8"
                     Foreground="{DynamicResource BarCountdownBrush}"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="textBoxTarget" Grid.Column="0" Height="28" VerticalAlignment="Center"
                     ToolTip="Seconds to count down"/>
            <Button x:Name="button" Grid.Column="1" Content="Start" Width="56" Height="28" Margin="6,0,0,0"
                    Background="{DynamicResource ButtonStartBrush}"/>
            <Button x:Name="button_Copy" Grid.Column="2" Content="Close" Width="56" Height="28" Margin="6,0,0,0"
                    Background="{DynamicResource ButtonCloseBrush}"/>
        </Grid>
    </Grid>
</Window>
